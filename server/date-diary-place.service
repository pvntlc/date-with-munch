[Unit]
Description=Date Diary - Naver place search proxy (FastAPI)
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/date-diary-place
EnvironmentFile=/opt/date-diary-place/.env
ExecStart=/opt/date-diary-place/.venv/bin/uvicorn main:app --host 127.0.0.1 --port 8011
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
